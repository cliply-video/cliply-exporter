{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Main window capabilities",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "sql:default",
    "sql:allow-load",
    "sql:allow-execute",
    "sql:allow-select",
    "dialog:default",
    "opener:default",
    "opener:allow-reveal-item-in-dir",
    "store:default",
    "log:default",
    {
      "identifier": "http:default",
      "allow": [{ "url": "http://localhost:*" }, { "url": "https://**" }]
    }
  ]
}
